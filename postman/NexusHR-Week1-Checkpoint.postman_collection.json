{
  "info": {
    "name": "NexusHR Week 1 Checkpoint",
    "_postman_id": "3f5e8b22-4d0c-4b72-bc61-39b172522f6d",
    "description": "Postman collection for the Week 1 backend checkpoint covering auth, employee, attendance, and leave basics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "authBaseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "employeeBaseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "employeeId",
      "value": "1"
    },
    {
      "key": "attendanceId",
      "value": "1"
    },
    {
      "key": "leaveRequestId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.accessToken) pm.collectionVariables.set('accessToken', response.accessToken);",
              "if (response.refreshToken) pm.collectionVariables.set('refreshToken', response.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@nexushr.local\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{authBaseUrl}}/api/auth/login",
          "host": [
            "{{authBaseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Create Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeCode\": \"EMP-1001\",\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"amit.sharma@example.com\",\n  \"phone\": \"9876543210\",\n  \"jobTitle\": \"Java Developer\",\n  \"hireDate\": \"2026-04-08\",\n  \"status\": \"ACTIVE\",\n  \"departmentCode\": \"ENG\",\n  \"roles\": [\"EMPLOYEE\"]\n}"
        },
        "url": {
          "raw": "{{employeeBaseUrl}}/api/employees",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        }
      }
    },
    {
      "name": "Get Employees",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{employeeBaseUrl}}/api/employees",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        }
      }
    },
    {
      "name": "Attendance Check-In",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"attendanceDate\": \"2026-04-08\",\n  \"status\": \"PRESENT\",\n  \"notes\": \"Week 1 checkpoint attendance\"\n}"
        },
        "url": {
          "raw": "{{employeeBaseUrl}}/api/attendance/check-in",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "attendance",
            "check-in"
          ]
        }
      }
    },
    {
      "name": "Attendance History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{employeeBaseUrl}}/api/attendance/employee/{{employeeId}}",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "attendance",
            "employee",
            "{{employeeId}}"
          ]
        }
      }
    },
    {
      "name": "Submit Leave Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"leaveType\": \"CASUAL\",\n  \"startDate\": \"2026-04-10\",\n  \"endDate\": \"2026-04-11\",\n  \"reason\": \"Family function\"\n}"
        },
        "url": {
          "raw": "{{employeeBaseUrl}}/api/leaves",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "leaves"
          ]
        }
      }
    },
    {
      "name": "Pending Leave Requests",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{employeeBaseUrl}}/api/leaves/pending",
          "host": [
            "{{employeeBaseUrl}}"
          ],
          "path": [
            "api",
            "leaves",
            "pending"
          ]
        }
      }
    }
  ]
}
